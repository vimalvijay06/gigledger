# ─── Spring Boot secrets — NEVER commit real credentials ─────────────────────
# The real application.properties contains DB passwords and JWT secrets.
# Use application.properties.example as the committed template instead.
backend/src/main/resources/application.properties

# application-local.properties is an optional override for local dev secrets
backend/src/main/resources/application-local.properties

